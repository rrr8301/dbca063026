2026-04-10T10:14:43.3957863Z     generate_migration_testcontainer_test.go:1693: Rollback DDL:
2026-04-10T10:14:43.3960434Z         CREATE VIEW `inventory_changes` AS SELECT 1 AS `product_id`, 1 AS `change_count`, 1 AS `last_changed`;
2026-04-10T10:14:43.3962048Z         
2026-04-10T10:14:43.3963600Z         CREATE TRIGGER `trg_inventory_delete` BEFORE DELETE ON `inventory` FOR EACH ROW BEGIN
2026-04-10T10:14:43.3965855Z             INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-10T10:14:43.3968218Z             VALUES (OLD.product_id, OLD.quantity, NULL, 'DELETE');
2026-04-10T10:14:43.3969599Z         END;
2026-04-10T10:14:43.3971601Z         
2026-04-10T10:14:43.3973468Z         CREATE TRIGGER `trg_inventory_insert` AFTER INSERT ON `inventory` FOR EACH ROW BEGIN
2026-04-10T10:14:43.3976359Z             INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-10T10:14:43.3978634Z             VALUES (NEW.product_id, NULL, NEW.quantity, 'INSERT');
2026-04-10T10:14:43.3980311Z         END;
2026-04-10T10:14:43.3981122Z         
2026-04-10T10:14:43.3982970Z         CREATE TRIGGER `trg_inventory_update` AFTER UPDATE ON `inventory` FOR EACH ROW BEGIN
2026-04-10T10:14:43.3986161Z             IF OLD.quantity != NEW.quantity THEN
2026-04-10T10:14:43.3988514Z                 INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-10T10:14:43.3990968Z                 VALUES (NEW.product_id, OLD.quantity, NEW.quantity, 'UPDATE');
2026-04-10T10:14:43.3992268Z             END IF;
2026-04-10T10:14:43.3993022Z         END;
2026-04-10T10:14:43.3993601Z         
2026-04-10T10:14:43.3999990Z         CREATE OR REPLACE VIEW `inventory_changes` AS select `inventory_log`.`product_id` AS `product_id`,count(0) AS `change_count`,max(`inventory_log`.`changed_at`) AS `last_changed` from `inventory_log` group by `inventory_log`.`product_id`;
