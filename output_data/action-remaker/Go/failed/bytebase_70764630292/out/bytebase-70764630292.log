2026-04-10T10:14:43.4475166Z         CREATE VIEW `monthly_sales` AS SELECT 1 AS `year`, 1 AS `month`, 1 AS `total_sales`;
2026-04-10T10:14:43.4475835Z         
2026-04-10T10:14:43.4476736Z         CREATE VIEW `top_products` AS SELECT 1 AS `product_name`, 1 AS `sale_count`, 1 AS `total_revenue`;
2026-04-10T10:14:43.4477672Z         
2026-04-10T10:14:43.4479913Z         CREATE OR REPLACE VIEW `monthly_sales` AS select year(`sales`.`sale_date`) AS `year`,month(`sales`.`sale_date`) AS `month`,sum(`sales`.`sale_amount`) AS `total_sales` from `sales` group by year(`sales`.`sale_date`),month(`sales`.`sale_date`);
2026-04-10T10:14:43.4481667Z         
2026-04-10T10:14:43.4483847Z         CREATE OR REPLACE VIEW `top_products` AS select `sales`.`product_name` AS `product_name`,count(0) AS `sale_count`,sum(`sales`.`sale_amount`) AS `total_revenue` from `sales` group by `sales`.`product_name` order by sum(`sales`.`sale_amount`) desc;
2026-04-10T10:14:43.4487190Z         
2026-04-10T10:14:43.4487974Z         CREATE FUNCTION `GetMonthlySalesTotal`(year INT, month INT) RETURNS decimal(10,2)
2026-04-10T10:14:43.4488765Z             READS SQL DATA
2026-04-10T10:14:43.4489243Z             DETERMINISTIC
2026-04-10T10:14:43.4489611Z         BEGIN
2026-04-10T10:14:43.4490093Z             DECLARE total DECIMAL(10, 2);
2026-04-10T10:14:43.4490804Z             SELECT COALESCE(SUM(sale_amount), 0) INTO total
2026-04-10T10:14:43.4491396Z             FROM sales
2026-04-10T10:14:43.4492157Z             WHERE YEAR(sale_date) = year AND MONTH(sale_date) = month;
2026-04-10T10:14:43.4493351Z             RETURN total;
2026-04-10T10:14:43.4494317Z         END;
2026-04-10T10:14:43.4495103Z         
2026-04-10T10:14:43.4497563Z         CREATE PROCEDURE `CalculateDiscount`(IN amount DECIMAL(10, 2), OUT discount DECIMAL(10, 2))
2026-04-10T10:14:43.4501861Z         BEGIN
2026-04-10T10:14:43.4503174Z             SET discount = amount * 0.1;
2026-04-10T10:14:43.4504357Z         END;
