2026-04-10T10:14:43.3748477Z         CREATE FUNCTION `GetAverageStat`(p_stat_name VARCHAR(100)) RETURNS decimal(10,2)
2026-04-10T10:14:43.3749287Z             READS SQL DATA
2026-04-10T10:14:43.3749737Z             DETERMINISTIC
2026-04-10T10:14:43.3750096Z         BEGIN
2026-04-10T10:14:43.3750603Z             DECLARE avg_value DECIMAL(10, 2);
2026-04-10T10:14:43.3751492Z             
2026-04-10T10:14:43.3752494Z             SELECT AVG(stat_value) INTO avg_value
2026-04-10T10:14:43.3753074Z             FROM system_stats
2026-04-10T10:14:43.3753600Z             WHERE stat_name = p_stat_name
2026-04-10T10:14:43.3754423Z             AND recorded_at >= DATE_SUB(NOW(), INTERVAL 7 DAY);
2026-04-10T10:14:43.3755301Z             
2026-04-10T10:14:43.3755737Z             RETURN COALESCE(avg_value, 0);
2026-04-10T10:14:43.3756099Z         END;
2026-04-10T10:14:43.3760990Z         
2026-04-10T10:14:43.3763678Z         CREATE PROCEDURE `RecordSystemStat`(
2026-04-10T10:14:43.3764853Z             IN p_stat_name VARCHAR(100),
2026-04-10T10:14:43.3765940Z             IN p_stat_value DECIMAL(10, 2)
2026-04-10T10:14:43.3766687Z         )
2026-04-10T10:14:43.3767217Z         BEGIN
2026-04-10T10:14:43.3768372Z             DECLARE EXIT HANDLER FOR SQLEXCEPTION
2026-04-10T10:14:43.3769850Z             BEGIN
2026-04-10T10:14:43.3770885Z                 ROLLBACK;
2026-04-10T10:14:43.3772002Z                 RESIGNAL;
2026-04-10T10:14:43.3772810Z             END;
2026-04-10T10:14:43.3773618Z             
2026-04-10T10:14:43.3774762Z             START TRANSACTION;
2026-04-10T10:14:43.3777234Z             
2026-04-10T10:14:43.3778536Z             INSERT INTO system_stats (stat_name, stat_value)
2026-04-10T10:14:43.3780418Z             VALUES (p_stat_name, p_stat_value);
2026-04-10T10:14:43.3781345Z             
2026-04-10T10:14:43.3782144Z             COMMIT;
2026-04-10T10:14:43.3783065Z         END;
2026-04-10T10:14:43.3783813Z         
2026-04-10T10:14:43.3786763Z         CREATE DEFINER=`root`@`%` EVENT `evt_cleanup_old_stats` ON SCHEDULE EVERY 1 DAY STARTS '2026-04-10 10:13:53' ON COMPLETION NOT PRESERVE ENABLE DO BEGIN
2026-04-10T10:14:43.3789768Z             DELETE FROM system_stats 
2026-04-10T10:14:43.3792125Z             WHERE recorded_at < DATE_SUB(NOW(), INTERVAL 30 DAY);
2026-04-10T10:14:43.3793260Z         END;
