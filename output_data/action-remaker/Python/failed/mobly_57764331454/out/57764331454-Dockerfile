FROM bugswarm/githubactionsjobrunners:ubuntu-22.04
RUN sudo rm -rf /var/lib/apt/lists/*
RUN sudo rm -rf /etc/apt/sources.list.d/*
RUN sudo apt-get clean
RUN sudo apt-get update && sudo apt-get -y install --only-upgrade openssl libssl-dev vim
RUN echo "TERM=dumb" >> /etc/environment
RUN touch /etc/reproducer-environment && chmod 777 /etc/reproducer-environment
RUN useradd -ms /bin/bash github
RUN echo "ALL ALL=(ALL:ALL) NOPASSWD: ALL" >> /etc/sudoers
ADD repo-to-docker.tar /home/github/build/
ADD --chown=github:github 57764331454/run.sh /usr/local/bin/
ADD --chown=github:github 57764331454/actions /home/github/57764331454/actions
ADD --chown=github:github 57764331454/steps /home/github/57764331454/steps
ADD --chown=github:github 57764331454/helpers /home/github/57764331454/helpers
ADD --chown=github:github 57764331454/event.json /home/github/57764331454/event.json
RUN chmod 777 /usr/local/bin/run.sh
RUN chmod -R 777 /home/github/57764331454
RUN rm -rf /home/linuxbrew && chown -R github:github /home
USER github
ENTRYPOINT ["/bin/bash", "-c"]
CMD ["/usr/local/bin/run.sh"]
