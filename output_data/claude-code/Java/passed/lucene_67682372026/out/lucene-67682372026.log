2026-03-19T02:43:11.5074246Z # tests.jvms=[N <= X]
2026-03-19T02:43:11.5074476Z #
2026-03-19T02:43:11.5074799Z # The number of test JVMs can be lower than the number of workers: this just means
2026-03-19T02:43:11.5075378Z # that two projects can run tests in parallel to saturate all the workers. The I/O and memory
2026-03-19T02:43:11.5075984Z # bandwidth limits will kick in quickly so even if you have a very beefy machine bumping
2026-03-19T02:43:11.5076434Z # it too high may not help.
2026-03-19T02:43:11.5076678Z #
2026-03-19T02:43:11.5077176Z # You can always override these settings locally using command line as well:
2026-03-19T02:43:11.5077811Z # gradlew -Ptests.jvms=N --max-workers=X
2026-03-19T02:43:11.5078114Z #
2026-03-19T02:43:11.5078305Z #############
2026-03-19T02:43:11.5078513Z # Test JVMS #
2026-03-19T02:43:11.5078710Z #############
2026-03-19T02:43:11.5078905Z #
2026-03-19T02:43:11.5079255Z # Test JVMs have their own set of arguments which can be customized. These are configured
2026-03-19T02:43:11.5079739Z # separately from the gradle workers, for example:
2026-03-19T02:43:11.5080059Z #
2026-03-19T02:43:11.5080251Z # tests.jvms=3
2026-03-19T02:43:11.5080477Z # tests.heapsize=512m
2026-03-19T02:43:11.5080726Z # tests.minheapsize=512m
2026-03-19T02:43:11.5081063Z # tests.jvmargs=-XX:+UseParallelGC -XX:TieredStopAtLevel=1
2026-03-19T02:43:11.5081410Z #
2026-03-19T02:43:11.5081764Z # See help/localSettings.txt for ways to discover which build options are available and
2026-03-19T02:43:11.5082212Z # how you can tweak them.
2026-03-19T02:43:11.5082453Z #
2026-03-19T02:43:11.5082643Z #################
2026-03-19T02:43:11.5082861Z # Gradle Daemon #
2026-03-19T02:43:11.5083084Z #################
2026-03-19T02:43:11.5083290Z #
2026-03-19T02:43:11.5083629Z # The gradle daemon is a background process that keeps an evaluated copy of the project
2026-03-19T02:43:11.5084206Z # structure, some caches, etc. It speeds up repeated builds quite a bit but if you don't
2026-03-19T02:43:11.5084777Z # like the idea of having a (sizeable) background process running in the background,
2026-03-19T02:43:11.5085202Z # disable it.
2026-03-19T02:43:11.5085409Z #
2026-03-19T02:43:11.5085614Z # org.gradle.daemon=[true, false]
2026-03-19T02:43:11.5085896Z # org.gradle.jvmargs=...
2026-03-19T02:43:11.5086213Z #############################################################################################
2026-03-19T02:43:11.5086472Z 
2026-03-19T02:43:11.5086577Z # UTF-8 as standard file encoding
2026-03-19T02:43:11.5086871Z systemProp.file.encoding=UTF-8
2026-03-19T02:43:11.5087243Z 
2026-03-19T02:43:11.5087354Z # Set up gradle JVM defaults.
2026-03-19T02:43:11.5087607Z #
2026-03-19T02:43:11.5087900Z # We also open up internal compiler modules for google java format.
2026-03-19T02:43:11.5088496Z org.gradle.jvmargs=-Xmx1g -XX:ReservedCodeCacheSize=256m -XX:TieredStopAtLevel=1 -XX:+UseParallelGC \
2026-03-19T02:43:11.5089105Z  --add-exports jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED \
2026-03-19T02:43:11.5089595Z  --add-exports jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED \
2026-03-19T02:43:11.5090093Z  --add-exports jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED \
2026-03-19T02:43:11.5090581Z  --add-exports jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED \
2026-03-19T02:43:11.5091051Z  --add-exports jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED
2026-03-19T02:43:11.5091328Z 
2026-03-19T02:43:11.5091444Z # Run at normal priority, in parallel
2026-03-19T02:43:11.5091739Z org.gradle.parallel=true
2026-03-19T02:43:11.5092006Z org.gradle.priority=normal
2026-03-19T02:43:11.5092171Z 
2026-03-19T02:43:11.5092370Z # This setting enables local task output caches. This will speed up
2026-03-19T02:43:11.5092856Z # your local builds in most cases but will also consume disk space in your
2026-03-19T02:43:11.5093273Z # gradle home. See LUCENE-10195 for details.
2026-03-19T02:43:11.5093579Z # org.gradle.caching=true
2026-03-19T02:43:11.5093740Z 
2026-03-19T02:43:11.5093954Z # Silence gradle warnings. We'll deal with them when we upgrade the wrapper.
2026-03-19T02:43:11.5094517Z org.gradle.warning.mode=none
2026-03-19T02:43:11.5094691Z 
2026-03-19T02:43:11.5094890Z # You may disable the background daemon if it consumes too much memory.
2026-03-19T02:43:11.5095274Z org.gradle.daemon=true
2026-03-19T02:43:11.5095530Z # timeout after 15 mins of inactivity.
2026-03-19T02:43:11.5095838Z org.gradle.daemon.idletimeout=900000
2026-03-19T02:43:11.5096035Z 
2026-03-19T02:43:11.5096157Z # Maximum number of parallel gradle workers.
2026-03-19T02:43:11.5096464Z org.gradle.workers.max=4
2026-03-19T02:43:11.5096628Z 
2026-03-19T02:43:11.5096769Z # Maximum number of test JVMs forked per test task.
2026-03-19T02:43:11.5097480Z tests.jvms=4
2026-03-19T02:43:11.5097616Z 
2026-03-19T02:43:11.5097725Z # Enable auto JVM provisioning.
2026-03-19T02:43:11.5098058Z org.gradle.java.installations.auto-download=true
2026-03-19T02:43:11.5098301Z 
2026-03-19T02:43:11.5098452Z # Set these to enable automatic JVM location discovery.
2026-03-19T02:43:11.5098894Z org.gradle.java.installations.fromEnv=JAVA25_HOME,RUNTIME_JAVA_HOME
2026-03-19T02:43:11.5099346Z #org.gradle.java.installations.paths=(custom paths)
