2026-02-03T18:31:59.8986798Z #fi
2026-02-03T18:31:59.8986870Z 
2026-02-03T18:31:59.8986927Z # sudo hint
2026-02-03T18:31:59.8987192Z if [ ! -e "$HOME/.sudo_as_admin_successful" ] && [ ! -e "$HOME/.hushlogin" ] ; then
2026-02-03T18:31:59.8987653Z     case " $(groups) " in *\ admin\ *|*\ sudo\ *)
2026-02-03T18:31:59.8987914Z     if [ -x /usr/bin/sudo ]; then
