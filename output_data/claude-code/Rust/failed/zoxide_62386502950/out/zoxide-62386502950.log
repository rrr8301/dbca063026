2026-02-03T18:31:59.8977078Z # System-wide .bashrc file for interactive bash(1) shells.
2026-02-03T18:31:59.8977379Z 
2026-02-03T18:31:59.8977689Z # To enable the settings / commands in this file for login shells as well,
2026-02-03T18:31:59.8978087Z # this file has to be sourced in /etc/profile.
2026-02-03T18:31:59.8978262Z 
2026-02-03T18:31:59.8978368Z # If not running interactively, don't do anything
2026-02-03T18:31:59.8978621Z [ -z "$PS1" ] && return
2026-02-03T18:31:59.8978749Z 
2026-02-03T18:31:59.8978881Z # check the window size after each command and, if necessary,
2026-02-03T18:31:59.8979180Z # update the values of LINES and COLUMNS.
2026-02-03T18:31:59.8979423Z shopt -s checkwinsize
2026-02-03T18:31:59.8979539Z 
2026-02-03T18:31:59.8979727Z # set variable identifying the chroot you work in (used in the prompt below)
2026-02-03T18:31:59.8980136Z if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
2026-02-03T18:31:59.8980435Z     debian_chroot=$(cat /etc/debian_chroot)
2026-02-03T18:31:59.8980653Z fi
2026-02-03T18:31:59.8980733Z 
2026-02-03T18:31:59.8980891Z # set a fancy prompt (non-color, overwrite the one in /etc/profile)
2026-02-03T18:31:59.8981277Z # but only if not SUDOing and have SUDO_PS1 set; then assume smart user.
2026-02-03T18:31:59.8981631Z if ! [ -n "${SUDO_USER}" -a -n "${SUDO_PS1}" ]; then
2026-02-03T18:31:59.8981920Z   PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
2026-02-03T18:31:59.8982819Z fi
2026-02-03T18:31:59.8982901Z 
2026-02-03T18:31:59.8983096Z # Commented out, don't overwrite xterm -T "title" -n "icontitle" by default.
2026-02-03T18:31:59.8983473Z # If this is an xterm set the title to user@host:dir
2026-02-03T18:31:59.8983726Z #case "$TERM" in
2026-02-03T18:31:59.8983882Z #xterm*|rxvt*)
2026-02-03T18:31:59.8984345Z #    PROMPT_COMMAND='echo -ne "\033]0;${USER}@${HOSTNAME}: ${PWD}\007"'
2026-02-03T18:31:59.8984644Z #    ;;
2026-02-03T18:31:59.8984774Z #*)
2026-02-03T18:31:59.8984902Z #    ;;
2026-02-03T18:31:59.8985025Z #esac
2026-02-03T18:31:59.8985109Z 
2026-02-03T18:31:59.8985207Z # enable bash completion in interactive shells
