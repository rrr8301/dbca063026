2026-04-04T04:00:55.6702356Z     generate_migration_testcontainer_test.go:1682:   View: inventory_changes, Action: CREATE
2026-04-04T04:00:55.6702699Z     generate_migration_testcontainer_test.go:1684: Function changes: 0
2026-04-04T04:00:55.6703111Z     generate_migration_testcontainer_test.go:1693: Rollback DDL:
2026-04-04T04:00:55.6703753Z         CREATE VIEW `inventory_changes` AS SELECT 1 AS `product_id`, 1 AS `change_count`, 1 AS `last_changed`;
2026-04-04T04:00:55.6703854Z         
2026-04-04T04:00:55.6704392Z         CREATE TRIGGER `trg_inventory_delete` BEFORE DELETE ON `inventory` FOR EACH ROW BEGIN
2026-04-04T04:00:55.6704983Z             INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-04T04:00:55.6705391Z             VALUES (OLD.product_id, OLD.quantity, NULL, 'DELETE');
2026-04-04T04:00:55.6705511Z         END;
2026-04-04T04:00:55.6705608Z         
2026-04-04T04:00:55.6706130Z         CREATE TRIGGER `trg_inventory_insert` AFTER INSERT ON `inventory` FOR EACH ROW BEGIN
2026-04-04T04:00:55.6706758Z             INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-04T04:00:55.6707164Z             VALUES (NEW.product_id, NULL, NEW.quantity, 'INSERT');
2026-04-04T04:00:55.6707280Z         END;
2026-04-04T04:00:55.6707379Z         
2026-04-04T04:00:55.6707908Z         CREATE TRIGGER `trg_inventory_update` AFTER UPDATE ON `inventory` FOR EACH ROW BEGIN
2026-04-04T04:00:55.6708189Z             IF OLD.quantity != NEW.quantity THEN
2026-04-04T04:00:55.6708889Z                 INSERT INTO inventory_log (product_id, old_quantity, new_quantity, change_type)
2026-04-04T04:00:55.6709454Z                 VALUES (NEW.product_id, OLD.quantity, NEW.quantity, 'UPDATE');
2026-04-04T04:00:55.6709597Z             END IF;
2026-04-04T04:00:55.6709704Z         END;
2026-04-04T04:00:55.6709799Z         
2026-04-04T04:00:55.6711376Z         CREATE OR REPLACE VIEW `inventory_changes` AS select `inventory_log`.`product_id` AS `product_id`,count(0) AS `change_count`,max(`inventory_log`.`changed_at`) AS `last_changed` from `inventory_log` group by `inventory_log`.`product_id`;
2026-04-04T04:00:55.6711473Z         
