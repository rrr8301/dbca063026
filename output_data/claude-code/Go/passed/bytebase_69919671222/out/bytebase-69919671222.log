2026-04-04T04:00:55.6827630Z     generate_migration_testcontainer_test.go:1693: Rollback DDL:
2026-04-04T04:00:55.6828230Z         CREATE VIEW `monthly_sales` AS SELECT 1 AS `year`, 1 AS `month`, 1 AS `total_sales`;
2026-04-04T04:00:55.6828337Z         
2026-04-04T04:00:55.6828941Z         CREATE VIEW `top_products` AS SELECT 1 AS `product_name`, 1 AS `sale_count`, 1 AS `total_revenue`;
2026-04-04T04:00:55.6829036Z         
2026-04-04T04:00:55.6830603Z         CREATE OR REPLACE VIEW `monthly_sales` AS select year(`sales`.`sale_date`) AS `year`,month(`sales`.`sale_date`) AS `month`,sum(`sales`.`sale_amount`) AS `total_sales` from `sales` group by year(`sales`.`sale_date`),month(`sales`.`sale_date`);
2026-04-04T04:00:55.6830700Z         
2026-04-04T04:00:55.6832290Z         CREATE OR REPLACE VIEW `top_products` AS select `sales`.`product_name` AS `product_name`,count(0) AS `sale_count`,sum(`sales`.`sale_amount`) AS `total_revenue` from `sales` group by `sales`.`product_name` order by sum(`sales`.`sale_amount`) desc;
2026-04-04T04:00:55.6832392Z         
2026-04-04T04:00:55.6832909Z         CREATE FUNCTION `GetMonthlySalesTotal`(year INT, month INT) RETURNS decimal(10,2)
2026-04-04T04:00:55.6833088Z             READS SQL DATA
2026-04-04T04:00:55.6833265Z             DETERMINISTIC
2026-04-04T04:00:55.6833374Z         BEGIN
2026-04-04T04:00:55.6833613Z             DECLARE total DECIMAL(10, 2);
2026-04-04T04:00:55.6833971Z             SELECT COALESCE(SUM(sale_amount), 0) INTO total
2026-04-04T04:00:55.6834128Z             FROM sales
2026-04-04T04:00:55.6834714Z             WHERE YEAR(sale_date) = year AND MONTH(sale_date) = month;
2026-04-04T04:00:55.6834892Z             RETURN total;
2026-04-04T04:00:55.6835011Z         END;
2026-04-04T04:00:55.6835108Z         
2026-04-04T04:00:55.6835883Z         CREATE PROCEDURE `CalculateDiscount`(IN amount DECIMAL(10, 2), OUT discount DECIMAL(10, 2))
2026-04-04T04:00:55.6836011Z         BEGIN
2026-04-04T04:00:55.6836270Z             SET discount = amount * 0.1;
2026-04-04T04:00:55.6836383Z         END;
2026-04-04T04:00:55.6836488Z         
