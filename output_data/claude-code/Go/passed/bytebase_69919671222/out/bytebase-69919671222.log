2026-04-04T04:00:55.6717574Z     generate_migration_testcontainer_test.go:1682:   View: product_inventory, Action: CREATE
2026-04-04T04:00:55.6717930Z     generate_migration_testcontainer_test.go:1684: Function changes: 0
2026-04-04T04:00:55.6718239Z     generate_migration_testcontainer_test.go:1693: Rollback DDL:
2026-04-04T04:00:55.6718822Z         CREATE VIEW `low_stock_products` AS SELECT 1 AS `id`, 1 AS `name`, 1 AS `price`, 1 AS `stock`;
2026-04-04T04:00:55.6718933Z         
2026-04-04T04:00:55.6719639Z         CREATE VIEW `product_inventory` AS SELECT 1 AS `id`, 1 AS `name`, 1 AS `price`, 1 AS `stock`, 1 AS `total_ordered`;
2026-04-04T04:00:55.6719884Z         
2026-04-04T04:00:55.6720387Z         CREATE TRIGGER `update_order_total` BEFORE INSERT ON `orders` FOR EACH ROW BEGIN
2026-04-04T04:00:55.6720672Z             DECLARE product_price DECIMAL(10, 2);
2026-04-04T04:00:55.6721213Z             SELECT price INTO product_price FROM products WHERE id = NEW.product_id;
2026-04-04T04:00:55.6721564Z             SET NEW.total = NEW.quantity * product_price;
2026-04-04T04:00:55.6721674Z         END;
2026-04-04T04:00:55.6721771Z         
2026-04-04T04:00:55.6723162Z         CREATE OR REPLACE VIEW `low_stock_products` AS select `products`.`id` AS `id`,`products`.`name` AS `name`,`products`.`price` AS `price`,`products`.`stock` AS `stock` from `products` where (`products`.`stock` < 10);
2026-04-04T04:00:55.6723270Z         
2026-04-04T04:00:55.6725273Z         CREATE OR REPLACE VIEW `product_inventory` AS select `p`.`id` AS `id`,`p`.`name` AS `name`,`p`.`price` AS `price`,`p`.`stock` AS `stock`,coalesce(sum(`o`.`quantity`),0) AS `total_ordered` from (`products` `p` left join `orders` `o` on((`p`.`id` = `o`.`product_id`))) group by `p`.`id`,`p`.`name`,`p`.`price`,`p`.`stock`;
2026-04-04T04:00:55.6725389Z         
2026-04-04T04:00:55.6725817Z         CREATE PROCEDURE `GetProductInventory`(IN product_name VARCHAR(100))
2026-04-04T04:00:55.6725927Z         BEGIN
2026-04-04T04:00:55.6726185Z             SELECT * FROM product_inventory
2026-04-04T04:00:55.6726540Z             WHERE name LIKE CONCAT('%', product_name, '%');
2026-04-04T04:00:55.6726646Z         END;
2026-04-04T04:00:55.6726781Z         
