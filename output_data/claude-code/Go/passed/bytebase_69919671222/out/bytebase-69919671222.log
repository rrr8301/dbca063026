2026-04-04T04:00:55.6730652Z         CREATE TABLE IF NOT EXISTS `sales_summary` (
2026-04-04T04:00:55.6730896Z           `id` int NOT NULL AUTO_INCREMENT,
2026-04-04T04:00:55.6731098Z           `product_id` int NOT NULL,
2026-04-04T04:00:55.6731651Z           `month_year` varchar(7) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci NOT NULL,
2026-04-04T04:00:55.6731931Z           `total_sales` decimal(10,2) DEFAULT NULL,
2026-04-04T04:00:55.6732193Z           `tax_amount` decimal(10,2) DEFAULT NULL,
2026-04-04T04:00:55.6732375Z           PRIMARY KEY (`id`),
2026-04-04T04:00:55.6732764Z           UNIQUE KEY `uk_product_month` (`product_id`, `month_year`)
2026-04-04T04:00:55.6733174Z         ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
2026-04-04T04:00:55.6733272Z         
2026-04-04T04:00:55.6734015Z         CREATE FUNCTION `CalculateTotalSales`(p_product_id INT, p_start_date DATE, p_end_date DATE) RETURNS decimal(10,2)
2026-04-04T04:00:55.6734196Z             READS SQL DATA
2026-04-04T04:00:55.6734362Z             DETERMINISTIC
2026-04-04T04:00:55.6734477Z         BEGIN
2026-04-04T04:00:55.6734728Z             DECLARE total DECIMAL(10, 2);
2026-04-04T04:00:55.6734838Z             
2026-04-04T04:00:55.6735265Z             SELECT COALESCE(SUM(quantity * unit_price), 0) INTO total
2026-04-04T04:00:55.6735416Z             FROM sales
2026-04-04T04:00:55.6735679Z             WHERE product_id = p_product_id
2026-04-04T04:00:55.6736121Z             AND sale_date BETWEEN p_start_date AND p_end_date;
2026-04-04T04:00:55.6736329Z             
2026-04-04T04:00:55.6736508Z             RETURN total;
2026-04-04T04:00:55.6736614Z         END;
2026-04-04T04:00:55.6736710Z         
2026-04-04T04:00:55.6737388Z         CREATE FUNCTION `GetTaxAmount`(amount DECIMAL(10, 2), tax_rate DECIMAL(5, 2)) RETURNS decimal(10,2)
2026-04-04T04:00:55.6737522Z             NO SQL
2026-04-04T04:00:55.6737685Z             DETERMINISTIC
2026-04-04T04:00:55.6737795Z         BEGIN
2026-04-04T04:00:55.6738066Z             RETURN amount * (tax_rate / 100);
2026-04-04T04:00:55.6738179Z         END;
