2026-04-04T04:00:55.6864754Z         CREATE FUNCTION `GetAverageStat`(p_stat_name VARCHAR(100)) RETURNS decimal(10,2)
2026-04-04T04:00:55.6864933Z             READS SQL DATA
2026-04-04T04:00:55.6865100Z             DETERMINISTIC
2026-04-04T04:00:55.6865210Z         BEGIN
2026-04-04T04:00:55.6865480Z             DECLARE avg_value DECIMAL(10, 2);
2026-04-04T04:00:55.6865592Z             
2026-04-04T04:00:55.6865871Z             SELECT AVG(stat_value) INTO avg_value
2026-04-04T04:00:55.6866066Z             FROM system_stats
2026-04-04T04:00:55.6866310Z             WHERE stat_name = p_stat_name
2026-04-04T04:00:55.6866681Z             AND recorded_at >= DATE_SUB(NOW(), INTERVAL 7 DAY);
2026-04-04T04:00:55.6866832Z             
2026-04-04T04:00:55.6867084Z             RETURN COALESCE(avg_value, 0);
2026-04-04T04:00:55.6867195Z         END;
2026-04-04T04:00:55.6867289Z         
2026-04-04T04:00:55.6867530Z         CREATE PROCEDURE `RecordSystemStat`(
2026-04-04T04:00:55.6867766Z             IN p_stat_name VARCHAR(100),
2026-04-04T04:00:55.6868107Z             IN p_stat_value DECIMAL(10, 2)
2026-04-04T04:00:55.6868208Z         )
2026-04-04T04:00:55.6868325Z         BEGIN
2026-04-04T04:00:55.6868604Z             DECLARE EXIT HANDLER FOR SQLEXCEPTION
2026-04-04T04:00:55.6868738Z             BEGIN
2026-04-04T04:00:55.6868927Z                 ROLLBACK;
2026-04-04T04:00:55.6869105Z                 RESIGNAL;
2026-04-04T04:00:55.6869232Z             END;
2026-04-04T04:00:55.6869345Z             
2026-04-04T04:00:55.6869545Z             START TRANSACTION;
2026-04-04T04:00:55.6869653Z             
2026-04-04T04:00:55.6870009Z             INSERT INTO system_stats (stat_name, stat_value)
2026-04-04T04:00:55.6870290Z             VALUES (p_stat_name, p_stat_value);
2026-04-04T04:00:55.6870402Z             
2026-04-04T04:00:55.6870542Z             COMMIT;
2026-04-04T04:00:55.6870652Z         END;
2026-04-04T04:00:55.6870758Z         
2026-04-04T04:00:55.6871728Z         CREATE DEFINER=`root`@`%` EVENT `evt_cleanup_old_stats` ON SCHEDULE EVERY 1 DAY STARTS '2026-04-04 02:21:35' ON COMPLETION NOT PRESERVE ENABLE DO BEGIN
2026-04-04T04:00:55.6871948Z             DELETE FROM system_stats 
2026-04-04T04:00:55.6872350Z             WHERE recorded_at < DATE_SUB(NOW(), INTERVAL 30 DAY);
2026-04-04T04:00:55.6872459Z         END;
