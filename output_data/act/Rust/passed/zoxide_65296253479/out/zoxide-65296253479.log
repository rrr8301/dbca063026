2026-03-01T10:02:51.0771570Z # System-wide .bashrc file for interactive bash(1) shells.
2026-03-01T10:02:51.0771975Z 
2026-03-01T10:02:51.0772507Z # To enable the settings / commands in this file for login shells as well,
