2026-03-01T10:02:51.0773536Z 
2026-03-01T10:02:51.0773732Z # If not running interactively, don't do anything
2026-03-01T10:02:51.0774208Z [ -z "$PS1" ] && return
2026-03-01T10:02:51.0774438Z 
2026-03-01T10:02:51.0774685Z # check the window size after each command and, if necessary,
2026-03-01T10:02:51.0775248Z # update the values of LINES and COLUMNS.
2026-03-01T10:02:51.0775683Z shopt -s checkwinsize
2026-03-01T10:02:51.0775917Z 
2026-03-01T10:02:51.0776256Z # set variable identifying the chroot you work in (used in the prompt below)
2026-03-01T10:02:51.0777040Z if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
2026-03-01T10:02:51.0777583Z     debian_chroot=$(cat /etc/debian_chroot)
2026-03-01T10:02:51.0777984Z fi
2026-03-01T10:02:51.0778125Z 
2026-03-01T10:02:51.0778407Z # set a fancy prompt (non-color, overwrite the one in /etc/profile)
2026-03-01T10:02:51.0779122Z # but only if not SUDOing and have SUDO_PS1 set; then assume smart user.
2026-03-01T10:02:51.0779870Z if ! [ -n "${SUDO_USER}" -a -n "${SUDO_PS1}" ]; then
2026-03-01T10:02:51.0780388Z   PS1='${debian_chroot:+($debian_chroot)}\u@\h:\w\$ '
2026-03-01T10:02:51.0780831Z fi
2026-03-01T10:02:51.0780971Z 
